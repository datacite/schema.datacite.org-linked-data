      "@context": {
        "@vocab": "https://schema.datacite.org/linked-data/vocab/nameType/"
      }
    },
    "givenName": {
      "@id": "property:givenName",
      "@type": "xsd:string"
    },
    "familyName": {
      "@id": "property:familyName",
      "@type": "xsd:string"
    },

    "nameIdentifier": {
      "@id": "property:nameIdentifier",
      "@type": "@id"
    },
    "nameIdentifierScheme": {
      "@id": "property:nameIdentifierScheme",
      "@type": "@id"
    },
    "schemeURI": {
      "@id": "property:schemeURI",
      "@type": "@id"
    },

    "affiliation": "property:affiliation",
    "affiliationIdentifier": {
      "@id": "property:affiliationIdentifier",
      "@type": "xsd:string"
    },
    "affiliationIdentifierScheme": {
      "@id": "property:affiliationIdentifierScheme",
      "@type": "xsd:string"
    },

    "titles": "property:titles",
    "title": {
      "@id": "property:title",
      "@type": "xsd:string"
    },
    "titleType": {
      "@id": "property:titleType",
      "@type": "@vocab",
      "@context": {
        "@vocab": "https://schema.datacite.org/linked-data/vocab/titleType/"
      }
    },

    "publisher": {
      "@id": "property:publisher",
      "@type": "xsd:string"
    },
    "publisherIdentifier": {
      "@id": "property:publisherIdentifier",
      "@type": "xsd:string"
    },
    "publisherIdentifierScheme": {
      "@id": "property:publisherIdentifierScheme",
      "@type": "xsd:string"
    },

    "publicationYear": {
      "@id": "property:publicationYear",
      "@type": "xsd:string"
    },

    "resourceType": {
      "@id": "property:resourceType",
      "@type": "xsd:string"
    },
    "resourceTypeGeneral": {
      "@id": "property:resourceTypeGeneral",
      "@type": "@vocab",
      "@context": {
        "@vocab": "https://schema.datacite.org/linked-data/vocab/resourceTypeGeneral/"
      }
    },

    "xml:lang": "xml:lang",
    "lang": "xml:lang"
  }
}