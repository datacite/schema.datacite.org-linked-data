{
  "@context": {
    "class": "https://schema.datacite.org/linked-data/class/",
    "property": "https://schema.datacite.org/linked-data/property/",
    "vocab": "https://schema.datacite.org/linked-data/vocab/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "xml": "http://www.w3.org/XML/1998/namespace",

    "Identifier": "class:Identifier",
    "Creator": "class:Creator",
    "Title": "class:Title",
    "Publisher": "class:Publisher",
    "ResourceType": "class:ResourceType",

    "identifier": {
      "@id": "property:identifier",
      "@type": "xsd:string"
    },
    "identifierType": {
      "@id": "property:identifierType",
      "@type": "@vocab",
      "@context": {
        "@vocab": "https://schema.datacite.org/linked-data/vocab/identifierType/"
      }
    },

    "creators": "property:creators",
    "creator": "property:creator",

